<%
  import org.exoplatform.commons.utils.PropertyManager;
  import org.exoplatform.commons.utils.CommonsUtils;
  import io.meeds.chat.service.utils.MatrixConstants;
  import io.meeds.chat.service.MatrixService;
  import io.meeds.chat.service.model.ChatSettingsEntity;

  MatrixService matrixService = CommonsUtils.getService(MatrixService.class);
  def requestContext = _ctx.getRequestContext();
  def userName = requestContext.getRemoteUser();
  if (userName != null && matrixService.isServiceEnabled()) {
    ChatSettingsEntity chatSettingsEntity = matrixService.loadChatSettings();
    String userMatrixId = matrixService.getMatrixIdForUser(userName);
    if(userMatrixId != null) {
      userMatrixId = "@" + userMatrixId + ":" + PropertyManager.getProperty(MatrixConstants.MATRIX_SERVER_NAME);
    }
%>
    <script type="text/javascript">
      const meedsChat = {};
      matrixServerName = '<%= PropertyManager.getProperty(MatrixConstants.MATRIX_SERVER_NAME) %>';
      matrixUserId = '<%= userMatrixId %>';
      <% if (chatSettingsEntity != null && (chatSettingsEntity.privateRoomsEnabled || chatSettingsEntity.spaceRoomsEnabled)) {%>
      meedsChat.privateRoomsEnabled = <%= chatSettingsEntity != null ? chatSettingsEntity.privateRoomsEnabled : false %>;
      meedsChat.spaceRoomsEnabled = <%= chatSettingsEntity != null ? chatSettingsEntity.spaceRoomsEnabled : false %>;
      <%}%>
    </script>
<%}%>
