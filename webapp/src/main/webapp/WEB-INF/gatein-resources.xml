<gatein-resources xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://www.exoplatform.org/xml/ns/gatein_resources_1_5 http://www.exoplatform.org/xml/ns/gatein_resources_1_5"
                  xmlns="http://www.exoplatform.org/xml/ns/gatein_resources_1_5">
  <portal-skin>
    <skin-name>Enterprise</skin-name>
    <skin-module>matrix</skin-module>
    <css-path>/css/matrix.css</css-path>
    <css-priority>120</css-priority>
    <filtered>true</filtered>
  </portal-skin>

  <portlet-skin>
    <application-name>matrix</application-name>
    <portlet-name>Matrix</portlet-name>
    <skin-name>Enterprise</skin-name>
    <additional-module>matrix</additional-module>
    <additional-module>PeopleList</additional-module>
  </portlet-skin>

  <portlet>
    <name>Matrix</name>
    <module>
      <script>
        <minify>false</minify>
        <path>/js/matrix.bundle.js</path>
      </script>
      <depends>
        <module>vue</module>
      </depends>
      <depends>
        <module>vuetify</module>
      </depends>
      <depends>
        <module>commonVueComponents</module>
      </depends>
      <depends>
        <module>suggester</module>
      </depends>
      <depends>
        <module>eXoVueI18n</module>
      </depends>
      <depends>
        <module>extensionRegistry</module>
      </depends>
      <depends>
        <module>vueDraggable</module>
      </depends>
      <depends>
        <module>emojiPicker</module>
      </depends>
      <depends>
        <module>spaceForm</module>
      </depends>
      <depends>
        <module>spaceMembersDrawer</module>
      </depends>
      <depends>
        <module>commons-cometd3</module>
        <as>cCometd</as>
      </depends>
      <depends>
        <module>jquery</module>
        <as>$</as>
      </depends>
    </module>
  </portlet>
  <portlet>
    <name>MatrixAdministration</name>
    <module>
      <script>
        <minify>false</minify>
        <path>/js/matrixAdministration.bundle.js</path>
      </script>
      <depends>
        <module>vue</module>
      </depends>
      <depends>
        <module>vuetify</module>
      </depends>
      <depends>
        <module>commonVueComponents</module>
      </depends>
      <depends>
        <module>suggester</module>
      </depends>
      <depends>
        <module>eXoVueI18n</module>
      </depends>
      <depends>
        <module>extensionRegistry</module>
      </depends>
      <depends>
        <module>vueDraggable</module>
      </depends>
      <depends>
        <module>emojiPicker</module>
      </depends>
      <depends>
        <module>spaceForm</module>
      </depends>
      <depends>
        <module>spaceMembersDrawer</module>
      </depends>
      <depends>
        <module>commons-cometd3</module>
        <as>cCometd</as>
      </depends>
      <depends>
        <module>jquery</module>
        <as>$</as>
      </depends>
    </module>
  </portlet>

  <module>
    <name>MatrixChatNotificationExtension</name>
    <load-group>notificationGRP</load-group>
    <script>
      <path>/js/matrixChatNotificationsExtension.bundle.js</path>
    </script>
    <depends>
      <module>vue</module>
    </depends>
    <depends>
      <module>vuetify</module>
    </depends>
    <depends>
      <module>eXoVueI18n</module>
    </depends>
    <depends>
      <module>extensionRegistry</module>
    </depends>
  </module>

  <module>
    <name>analyticsExtensionMatrix</name>
    <load-group>commonAnalyticsVueComponentsGroup</load-group>
    <script>
      <path>/js/analyticsExtensionMatrix.bundle.js</path>
    </script>
    <depends>
      <module>vue</module>
    </depends>
    <depends>
      <module>vuetify</module>
    </depends>
    <depends>
      <module>eXoVueI18n</module>
    </depends>
    <depends>
      <module>extensionRegistry</module>
    </depends>
    <depends>
      <module>commonVueComponents</module>
    </depends>
  </module>

  <module>
    <name>MatrixUserSettingsNotificationsExtension</name>
    <load-group>UserSettingNotificationsGRP</load-group>
    <script>
      <path>/js/userSettingsNotificationsExtension.bundle.js</path>
    </script>
    <depends>
      <module>vue</module>
    </depends>
    <depends>
      <module>vuetify</module>
    </depends>
    <depends>
      <module>eXoVueI18n</module>
    </depends>
    <depends>
      <module>extensionRegistry</module>
    </depends>
    <depends>
      <module>commonVueComponents</module>
    </depends>
  </module>

  <module>
    <name>MatrixSpaceTemplateManagementExtension</name>
    <load-group>SpaceTemplateManagement</load-group>
    <script>
      <path>/js/matrixSpaceTemplateExtension.bundle.js</path>
    </script>
    <depends>
      <module>vue</module>
    </depends>
    <depends>
      <module>vuetify</module>
    </depends>
    <depends>
      <module>eXoVueI18n</module>
    </depends>
    <depends>
      <module>extensionRegistry</module>
    </depends>
    <depends>
      <module>commonVueComponents</module>
    </depends>
  </module>

  <module>
    <name>matrixManageSpacesExtension</name>
    <load-group>SpacesAdministration</load-group>
    <script>
      <path>/js/matrixSpacesAdministrationExtension.bundle.js</path>
    </script>
    <depends>
      <module>vue</module>
    </depends>
    <depends>
      <module>vuetify</module>
    </depends>
    <depends>
      <module>eXoVueI18n</module>
    </depends>
    <depends>
      <module>extensionRegistry</module>
    </depends>
    <depends>
      <module>commonVueComponents</module>
    </depends>
  </module>

</gatein-resources>
